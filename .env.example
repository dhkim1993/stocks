# =========================
# 네이버 뉴스 API (선택)
# 없으면 네이버 뉴스 검색 페이지 크롤링으로 동작
# =========================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# =========================
# OpenAI 요약 (선택)
# =========================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =========================
# 텔레그램 전송 (필수 — ark_monitor.py 에서도 사용)
# =========================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_REALTIME_ENABLED=true
TELEGRAM_SEND_DIGEST=true
TELEGRAM_MAX_ALERTS=20

# =========================
# 실행 설정 (news_automation.py)
# =========================
LOOKBACK_HOURS=24
RUN_TIME=09:00
OUTPUT_DIR=.
STATE_FILE=sent_items.json

# =========================
# ARK 펀드 모니터링 설정 (ark_monitor.py)
# =========================
# 포트폴리오 상태 저장 파일
ARK_STATE_FILE=ark_state.json
